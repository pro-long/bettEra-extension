{
  "manifest_version": 3,
  "name": "bettEra",
  "version": "1.0",
  "description": "A Chrome extension for betting on Warera.io",
  "content_scripts": [
    {
      "matches": ["*://app.warera.io/*"],
      "js": ["ui.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://app.warera.io/*"],
      "js": ["hook.js"],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["naps.json"],
      "matches": ["*://app.warera.io/*"]
    }
  ]
}